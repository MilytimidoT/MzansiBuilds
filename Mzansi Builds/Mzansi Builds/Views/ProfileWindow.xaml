<Window x:Class="Mzansi_Builds.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        Height="700"
        Width="1000"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔝 NAVBAR -->
        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid Margin="30,0" Height="60">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Text="MzansiBuilds"
                           Foreground="#16A34A"
                           FontWeight="Bold"
                           FontSize="22"
                           VerticalAlignment="Center"/>

                <!-- Feed -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Border Background="#DCFCE7"
                            CornerRadius="8"
                            Padding="12,6"
                            Cursor="Hand"
                            MouseDown="OpenFeed_Click">

                        <TextBlock Text="🏠 Feed"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Right -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock Text="🔔"
                               Cursor="Hand"
                               Margin="0,0,15,0"
                               MouseDown="OpenNotifications"/>

                    <TextBlock x:Name="UserEmailText"
                               Cursor="Hand"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               MouseDown="OpenProfile_Click"/>

                    <TextBlock Text="Logout"
                               Cursor="Hand"
                               Foreground="#DC2626"
                               MouseDown="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20"
                        HorizontalAlignment="Center"
                        Width="850">

                <!-- PROFILE CARD -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="0,0,0,20"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock x:Name="NameText"
                                   FontSize="26"
                                   FontWeight="Bold"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="✉️" Margin="0,0,6,0"/>
                            <TextBlock x:Name="EmailText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="📍" Margin="0,0,6,0"/>
                            <TextBlock x:Name="CityText"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- POSTS TITLE -->
                <TextBlock Text="My Posts"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- POSTS -->
                <ItemsControl x:Name="UserPosts">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="White"
                                    Padding="18"
                                    Margin="0,10"
                                    CornerRadius="16"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">

                                <StackPanel>

                                    <!-- CONTENT -->
                                    <TextBlock Text="{Binding Content}"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"/>
                                    

                                    <!-- DATE -->
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:g}'}"
                                               Foreground="Gray"
                                               Margin="0,5"/>

                                    <!-- AUTHOR -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="✉️" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding AuthorEmail}"/>
                                    </StackPanel>

                                    <!-- GITHUB BUTTON -->
                                    <Border Background="#111827"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,10,0,0"
                                            Cursor="Hand"
                                            MouseDown="GithubLink_Click">

                                        <TextBlock Text="🔗 View on GitHub"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>