<Window x:Class="Mzansi_Builds.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="720" Width="1000" Background="#F7F8F9">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="BorderBrush" Value="#E6E6E6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <ScrollViewer>
        <StackPanel Margin="32">
            <Border Style="{StaticResource Card}" Width="880">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="100" Height="100" Fill="{Binding CurrentUser.ProfileImagePath, Converter={StaticResource ProfileImageConverter}}" Stroke="#E6E6E6" Grid.Column="0"/>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="{Binding CurrentUser.Name}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentUser.Bio}" Foreground="#6B7280" Margin="0,6,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="📍"/>
                            <TextBlock Text="{Binding CurrentUser.City}" Margin="6,0,12,0"/>
                            <TextBlock Text="{Binding CurrentUser.JoinedAt, StringFormat='Joined {0:MMMM yyyy}'}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <StackPanel Margin="0,0,36,0">
                                <TextBlock Text="{Binding CurrentUser.FollowersCount}" FontWeight="Bold"/>
                                <TextBlock Text="Followers" Foreground="#6B7280"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,36,0">
                                <TextBlock Text="{Binding CurrentUser.FollowingCount}" FontWeight="Bold"/>
                                <TextBlock Text="Following" Foreground="#6B7280"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentUser.PostsCount}" FontWeight="Bold"/>
                                <TextBlock Text="Posts" Foreground="#6B7280"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Posts" FontSize="18" FontWeight="Bold" Margin="0,12,0,6"/>
            <ItemsControl ItemsSource="{Binding Posts}" Width="880">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MMMM d, yyyy HH:mm}'}" Foreground="#94A3B8" FontSize="12"/>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding GithubLink}" Foreground="#10B981" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="No posts yet" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="{Binding Posts.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</Window>
