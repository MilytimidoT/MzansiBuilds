<Window x:Class="Mzansi_Builds.Views.FeedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Mzansi_Builds.Models"
        Title="Feed"
        Height="720"
        Width="1100"
        Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= NAVBAR ================= -->
        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">

            <Grid Height="65" Margin="30,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <TextBlock Text="MzansiBuilds"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#16A34A"
                           VerticalAlignment="Center"/>

                <!-- CENTER -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Border Background="#DCFCE7"
                            CornerRadius="10"
                            Padding="10,5"
                            Cursor="Hand"
                            MouseDown="OpenFeed_Click">

                        <TextBlock Text="🏠 Feed"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- RIGHT -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- NOTIFICATIONS -->
                    <Grid Cursor="Hand"
                          Margin="0,0,15,0"
                          MouseDown="OpenNotifications">

                        <TextBlock Text="🔔"
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                        <Border Background="Green"
                                Width="16"
                                Height="16"
                                CornerRadius="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10,-5,0,0">

                            <TextBlock Text="0"
                                       Foreground="White"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="UserEmailText"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               MouseDown="OpenProfile_Click"/>

                    <TextBlock Text="Logout"
                               Cursor="Hand"
                               Foreground="Black"
                               MouseDown="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= CONTENT ================= -->
        <ScrollViewer Grid.Row="1">

            <StackPanel Width="650"
                        HorizontalAlignment="Center"
                        Margin="20">

                <!-- WELCOME -->
                <TextBlock x:Name="WelcomeText"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,15,0,20"
                           Foreground="#111827"/>

                <!-- ================= POST COMPOSER ================= -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,0,20"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Create a post"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- POST TEXT -->
                        <Border Background="#F9FAFB"
                                CornerRadius="10"
                                Padding="10">

                            <TextBox x:Name="ContentTextBox"
                                     Height="90"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"/>
                        </Border>

                        <!-- ================= GITHUB INPUT ================= -->
                        <Border Background="#0D1117"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,10,0,0">

                            <DockPanel>

                                <!-- GitHub ICON -->
                                <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="White"
                                              Data="M12 0.297C5.37 0.297 0 5.67 0 12.297
                                              c0 5.303 3.438 9.8 8.205 11.387
                                              .6.113.82-.258.82-.577
                                              0-.285-.01-1.04-.015-2.04
                                              -3.338.724-4.042-1.61-4.042-1.61
                                              -.546-1.387-1.333-1.757-1.333-1.757
                                              -1.09-.745.084-.729.084-.729
                                              1.205.084 1.84 1.236 1.84 1.236
                                              1.07 1.835 2.807 1.304 3.495.997
                                              .108-.776.42-1.305.763-1.605
                                              -2.665-.305-5.466-1.332-5.466-5.93
                                              0-1.31.468-2.38 1.235-3.22
                                              -.135-.303-.54-1.523.105-3.176
                                              0 0 1.005-.322 3.3 1.23
                                              .96-.267 1.98-.4 3-.405
                                              1.02.005 2.04.138 3 .405
                                              2.28-1.552 3.285-1.23 3.285-1.23
                                              .645 1.653.24 2.873.12 3.176
                                              .765.84 1.23 1.91 1.23 3.22
                                              0 4.61-2.805 5.625-5.475 5.92
                                              .435.375.81 1.102.81 2.222
                                              0 1.606-.015 2.896-.015 3.286
                                              0 .315.21.69.825.57
                                              C20.565 22.092 24 17.592 24 12.297
                                              24 5.67 18.627 0.297 12 0.297z"/>
                                    </Canvas>
                                </Viewbox>

                                <!-- INPUT -->
                                <TextBox x:Name="GithubTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         CaretBrush="White"
                                         FontSize="13"
                                         TextChanged="GithubTextBox_TextChanged"
                                         ToolTip="GitHub link (optional)"/>
                            </DockPanel>
                        </Border>

                        <!-- 🧩 GITHUB CHIP (NO LINK SHOWN) -->
                        <Border x:Name="GithubChip"
                                Background="#111827"
                                CornerRadius="20"
                                Padding="8,4"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Visibility="Collapsed">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🐙"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GithubLink}"
                                           Foreground="#2563EB"
                                           TextDecorations="Underline"
                                           Cursor="Hand"
                                           MouseDown="GithubLink_Click"/>

                                <TextBlock x:Name="GithubChipText"
                                           Text="GitHub Attached"
                                           Foreground="White"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- ACTIONS -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0">

                            <Button Content="📎 Attach"
                                    Width="120"
                                    Height="35"
                                    Background="#F3F4F6"
                                    BorderBrush="#E5E7EB"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="AttachButton_Click"/>

                            <TextBlock Width="10"/>

                            <Button Content="🚀 Post"
                                    Width="120"
                                    Height="35"
                                    Background="#16A34A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="PostButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ================= FEED ================= -->
                <ItemsControl x:Name="PostsList">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Post}">

                            <Border Background="White"
                                    CornerRadius="16"
                                    Padding="15"
                                    Margin="0,0,0,15"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">

                                <StackPanel>

                                    <!-- USER -->
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="42"
                                                 Height="42"
                                                 Fill="#22C55E"/>

                                        <TextBlock Text="{Binding AuthorName}"
                                                   FontWeight="Bold"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>

                                    <!-- POST -->
                                    <TextBlock Text="{Binding Content}"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"/>

                                    <!-- GITHUB DISPLAY -->
                                    <TextBlock Text="🐙 GitHub Repo"
                                               Foreground="#2563EB"
                                               Margin="0,5,0,0"
                                               TextDecorations="Underline"/>
                                    <!-- ATTACHMENTS -->
                                    <ItemsControl ItemsSource="{Binding AttachmentPaths}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Border CornerRadius="10"
                    Margin="0,10,0,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                                                    <Image Source="{Binding}"
                       Height="200"
                       Stretch="UniformToFill"/>
                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- LIKE -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">

                                        <Button Content="❤️ Like"
                                                Tag="{Binding}"
                                                Click="Like_Click"/>

                                        <TextBlock Text="{Binding Likes.Count}"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>

                                    <!-- COMMENTS -->
                                    <ItemsControl ItemsSource="{Binding Comments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,4">
                                                    <Run Text="{Binding AuthorEmail}" FontWeight="Bold"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Text}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- COMMENT BOX -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">

                                        <TextBox Width="300"
                                                 Height="30"
                                                 Tag="{Binding}"/>

                                        <Button Content="Post"
                                                Tag="{Binding}"
                                                Click="Comment_Click"
                                                Margin="8,0,0,0"
                                                Background="#111827"
                                                Foreground="White"
                                                BorderThickness="0"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>