<Window x:Class="Mzansi_Builds.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="420" Width="420" WindowStartupLocation="CenterScreen">
    <Grid Background="#F6FFF6" Margin="12">
        <Border Background="White" CornerRadius="8" Padding="20" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center" >
            <StackPanel>
                <TextBlock Text="Login" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Email" Margin="0,8,0,2"/>
                <TextBox x:Name="EmailBox" Height="30"/>

                <TextBlock Text="Password" Margin="0,8,0,2"/>
                <PasswordBox x:Name="PasswordBox" Height="30"/>

                <Button Content="Sign In" Click="Login_Click" Height="36" Margin="0,12,0,0" Background="#0FA84D" Foreground="White" />

                <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Run Text="Don't have an account? "/>
                    <Hyperlink Click="GoToRegister_Click">Sign up</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
