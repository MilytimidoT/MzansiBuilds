<Window x:Class="Mzansi_Builds.Views.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Friends"
        Height="650"
        Width="800"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Friends"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <!-- 🔍 USERS -->
                <TextBlock Text="Discover People" FontWeight="Bold"/>
                <ItemsControl x:Name="UsersList"/>

                <!-- 📩 REQUESTS -->
                <TextBlock Text="Friend Requests"
                           FontWeight="Bold"
                           Margin="0,20,0,5"/>
                <ItemsControl x:Name="RequestsList"/>

                <!-- 👥 FRIENDS -->
                <TextBlock Text="Your Friends"
                           FontWeight="Bold"
                           Margin="0,20,0,5"/>
                <ItemsControl x:Name="FriendsList"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>