<Window x:Class="Mzansi_Builds.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register" Height="520" Width="420" WindowStartupLocation="CenterScreen">
    <Grid Background="#F6FFF6" Margin="12">
        <Border Background="White" CornerRadius="8" Padding="20" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Sign Up" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Text="Full Name" Margin="0,6,0,2"/>
                <TextBox x:Name="NameBox" Height="30"/>

                <TextBlock Text="Email" Margin="0,8,0,2"/>
                <TextBox x:Name="EmailBox" Height="30"/>

                <TextBlock Text="City" Margin="0,8,0,2"/>
                <TextBox x:Name="CityBox" Height="30"/>
                <Button Content="Upload Profile Image"
        Click="UploadImage_Click"/>
                <TextBlock x:Name="ImagePathText"/>

                <TextBlock Text="Password" Margin="0,8,0,2"/>
                <PasswordBox x:Name="PasswordBox" Height="30"/>

                <TextBlock Text="Confirm Password" Margin="0,8,0,2"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="30"/>

                <Button Content="Create Account" Click="Register_Click" Height="36" Margin="0,12,0,0" Background="#0FA84D" Foreground="White"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Run Text="Already have an account? "/>
                    <Hyperlink Click="GoToLogin_Click">Sign in</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>