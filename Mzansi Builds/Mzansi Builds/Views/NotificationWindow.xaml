<Window x:Class="Mzansi_Builds.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notifications"
        Height="700"
        Width="1000"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= NAVBAR ================= -->
        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">

            <Grid Margin="30,0" Height="60">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Text="MzansiBuilds"
                           Foreground="#16A34A"
                           FontWeight="Bold"
                           FontSize="22"
                           VerticalAlignment="Center"/>

                <!-- Feed Button -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Border Background="#DCFCE7"
                            Padding="12,6"
                            CornerRadius="8"
                            Cursor="Hand"
                            MouseDown="OpenFeed_Click">

                        <TextBlock Text="🏠 Feed"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Right Side -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- 🔔 ICON + BADGE -->
                    <Grid Margin="0,0,15,0">

                        <TextBlock Text="🔔"
                                   FontSize="18"
                                   VerticalAlignment="Center"/>

                        <Border Background="Red"
                                Width="18"
                                Height="18"
                                CornerRadius="9"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10,-5,0,0"
                                Visibility="{Binding HasNotifications}">

                            <TextBlock Text="{Binding NotificationCount}"
                                       Foreground="White"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                    </Grid>

                    <!-- Profile -->
                    <TextBlock x:Name="UserEmailText"
                               Cursor="Hand"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               MouseDown="OpenProfile_Click"/>

                    <!-- Logout -->
                    <TextBlock Text="Logout"
                               Cursor="Hand"
                               MouseDown="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= CONTENT ================= -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20"
                        Width="600"
                        HorizontalAlignment="Center">

                <TextBlock Text="Notifications"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,10"/>

                <ItemsControl x:Name="NotificationsList">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="White"
                                    Padding="12"
                                    Margin="0,8"
                                    CornerRadius="10"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">

                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>